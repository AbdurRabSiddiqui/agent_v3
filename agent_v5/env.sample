## Ollama server (Lambda instance: local Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434

## Local model preferences (Ollama)
#
# The agent considers **all installed models** (from `ollama list`).
# These variables are only *preferences / defaults*.
#
# Use ANY model name shown by: `ollama list`
# For math-heavy benchmarks (MATH-500 / SWE-bench), prefer DeepSeek-R1 even for “tiny/fast”
# so we don’t select a small non-math model just because it formats output well.
OLLAMA_TINY_MODEL=deepseek-r1:8b
OLLAMA_FAST_MODEL=deepseek-r1:14b
OLLAMA_GENERAL_MODEL=deepseek-r1:8b
OLLAMA_TOOL_MODEL=deepseek-r1:8b
#
# Local strong defaults (no cloud models)
OLLAMA_STRONG_MODEL=deepseek-r1:32b
OLLAMA_ULTRA_MODEL=deepseek-r1:32b
#
# Optional: math-specific DeepSeek-R1 tiers
OLLAMA_MATH_SMALL_MODEL=deepseek-r1:8b
OLLAMA_MATH_MEDIUM_MODEL=deepseek-r1:14b
OLLAMA_MATH_LARGE_MODEL=deepseek-r1:32b
#
# Cloud examples (commented out)
# OLLAMA_STRONG_MODEL=deepseek-v3.1:671b-cloud
# OLLAMA_ULTRA_MODEL=gpt-oss:120b-cloud

## Agent-driven model selection
#
# How many local models to compare per prompt. Default: 3
MODEL_SELECT_CANDIDATES=3
#
# HELIOS-inspired early-stop (non-tool prompts):
# - draft with a smaller model
# - verify “good enough” with a cheap verifier model
# - accept early or escalate
# - fall back to draft+judge tournament when uncertain
MODEL_SELECT_EARLY_STOP=1
MODEL_SELECT_FORCE_TOURNAMENT=0
MODEL_SELECT_VERIFY=1
#
# Verifier model (should be cheap but reliable; for MATH-500 prefer a math-capable small model)
OLLAMA_VERIFY_MODEL=deepseek-r1:8b
MODEL_SELECT_VERIFY_TIMEOUT_S=25
MODEL_SELECT_ACCEPT_THRESHOLD=0.78
MODEL_SELECT_REJECT_THRESHOLD=0.78
#
# Judge model used to pick the best draft answer
OLLAMA_JUDGE_MODEL=deepseek-r1:32b
#
# Judge temperature (recommend 0.0 for determinism)
MODEL_SELECT_JUDGE_TEMP=0.0
#
# Timeouts (seconds): prevent hangs from blocking progress
# - drafts: per-candidate answer generation
# - judge: per-judge attempt
# - tools: per tool-agent attempt
#
# Recommended for long runs on A100 (SWE-bench / MATH-500):
MODEL_SELECT_DRAFT_TIMEOUT_S=600
# Keep the strongest judge (32b) as primary; only fail over after a longer wait.
MODEL_SELECT_JUDGE_TIMEOUT_S=1800
MODEL_SELECT_TOOL_TIMEOUT_S=1800
#
# Truncation limit for drafts/judge output stored in traces
MODEL_SELECT_MAX_OUTPUT_CHARS=2000
#
# How long to cache `ollama list` results (seconds)
MODEL_LIST_TTL_S=5
#
# Local-only: do NOT allow *-cloud entries from `ollama list`
MODEL_ALLOW_OLLAMA_CLOUD=0
MODEL_ALLOW_CLOUD=0
#
# Agent temperatures (falls back to legacy ROUTER_TEMP_* if unset)
AGENT_TEMP_TOOL=0.1
AGENT_TEMP_MATH=0.2
AGENT_TEMP_CODE=0.2
AGENT_TEMP_GENERAL=0.3
#
# Debug printing (also accepts legacy ROUTER_DEBUG)
AGENT_DEBUG=0
#
# Tracing (JSONL): includes model selection + tool calls + MATH-500 per-item events
AGENT_TRACE_PATH=logs/agent_trace.jsonl
#
# Live power trace label file (written by agent, read by gpu_energy_logger.py)
POWER_LABEL_PATH=logs/power_label.json
#
# Agent loop controls
AGENT_MAX_ITERATIONS=10
AGENT_MAX_HISTORY_MESSAGES=12

## Agent Lightning + VERL (policy model training)
#
# Used by: training/train_policy_model_verl.py
# Goal: train a small verifier/policy model that outputs strict JSON:
#   {"accept": <bool>, "confidence": <0..1>, "reason": "<short>"}
#
# Recommended starting point for 1x A100 40GB:
VERL_POLICY_MODEL=Qwen/Qwen2.5-1.5B-Instruct
VERL_EPOCHS=1
VERL_N_GPUS=1
VERL_TP=1
VERL_GPU_UTIL=0.60
VERL_MAX_PROMPT_LENGTH=4096
VERL_MAX_RESPONSE_LENGTH=128
VERL_TRAIN_BATCH_SIZE=8
VERL_SAMPLES_PER_PROMPT=2
VERL_PPO_MINI_BATCH=8
VERL_PPO_MICRO_BATCH=2
VERL_REF_MICRO_BATCH=2
VERL_LR=1e-6
#
# Reward shaping used by training scripts
RL_LAMBDA_STRONG=0.05
RL_LAMBDA_TIME=0.0
RL_LAMBDA_ENERGY=0.0

