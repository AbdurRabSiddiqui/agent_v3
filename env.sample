## Ollama server (Lambda instance: local Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434

## Local model preferences (Ollama)
#
# The agent considers **all installed models** (from `ollama list`).
# These variables are only *preferences / defaults*.
#
# Use ANY model name shown by: `ollama list`
OLLAMA_TINY_MODEL=phi3:mini
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_GENERAL_MODEL=deepseek-r1:8b
OLLAMA_TOOL_MODEL=deepseek-r1:8b
#
# Local strong defaults (no cloud models)
OLLAMA_STRONG_MODEL=deepseek-r1:32b
OLLAMA_ULTRA_MODEL=deepseek-r1:32b
#
# Optional: math-specific DeepSeek-R1 tiers
OLLAMA_MATH_SMALL_MODEL=deepseek-r1:8b
OLLAMA_MATH_MEDIUM_MODEL=deepseek-r1:14b
OLLAMA_MATH_LARGE_MODEL=deepseek-r1:32b
#
# Cloud examples (commented out)
# OLLAMA_STRONG_MODEL=deepseek-v3.1:671b-cloud
# OLLAMA_ULTRA_MODEL=gpt-oss:120b-cloud

## Agent-driven model selection
#
# How many local models to compare per prompt (draft+judge). Default: 3
MODEL_SELECT_CANDIDATES=3
#
# Judge model used to pick the best draft answer
OLLAMA_JUDGE_MODEL=deepseek-r1:32b
#
# Judge temperature (recommend 0.0 for determinism)
MODEL_SELECT_JUDGE_TEMP=0.0
#
# Timeouts (seconds): prevent hangs from blocking progress
# - drafts: per-candidate answer generation
# - judge: per-judge attempt
# - tools: per tool-agent attempt
MODEL_SELECT_DRAFT_TIMEOUT_S=180
MODEL_SELECT_JUDGE_TIMEOUT_S=90
MODEL_SELECT_TOOL_TIMEOUT_S=240
#
# Truncation limit for drafts/judge output stored in traces
MODEL_SELECT_MAX_OUTPUT_CHARS=2000
#
# How long to cache `ollama list` results (seconds)
MODEL_LIST_TTL_S=5
#
# Local-only: do NOT allow *-cloud entries from `ollama list`
MODEL_ALLOW_OLLAMA_CLOUD=0
MODEL_ALLOW_CLOUD=0
#
# Agent temperatures (falls back to legacy ROUTER_TEMP_* if unset)
AGENT_TEMP_TOOL=0.1
AGENT_TEMP_MATH=0.2
AGENT_TEMP_CODE=0.2
AGENT_TEMP_GENERAL=0.3
#
# Debug printing (also accepts legacy ROUTER_DEBUG)
AGENT_DEBUG=0
#
# Tracing (JSONL): includes model selection + tool calls + MATH-500 per-item events
AGENT_TRACE_PATH=logs/agent_trace.jsonl
#
# Live power trace label file (written by agent, read by gpu_energy_logger.py)
POWER_LABEL_PATH=logs/power_label.json
#
# Agent loop controls
AGENT_MAX_ITERATIONS=10
AGENT_MAX_HISTORY_MESSAGES=12

